# Copy this file to .env.test and fill in the values.
# Lines beginning with # are ignored.

# ---- MySQL / MariaDB -------------------------------------------------
# Setting GOBL_TEST_MYSQL_USER enables the MySQL live-DB test suite.
GOBL_TEST_MYSQL_HOST=127.0.0.1
GOBL_TEST_MYSQL_PORT=3306
GOBL_TEST_MYSQL_DB=gobl_test
GOBL_TEST_MYSQL_USER=gobl_test
GOBL_TEST_MYSQL_PASSWORD=gobl_test

# ---- PostgreSQL ------------------------------------------------------
# Setting GOBL_TEST_POSTGRESQL_USER enables the PostgreSQL live-DB test suite.
GOBL_TEST_POSTGRESQL_HOST=127.0.0.1
GOBL_TEST_POSTGRESQL_PORT=5432
GOBL_TEST_POSTGRESQL_DB=gobl_test
GOBL_TEST_POSTGRESQL_USER=gobl_test
GOBL_TEST_POSTGRESQL_PASSWORD=gobl_test

# ---- SQLite ----------------------------------------------------------
# Setting GOBL_TEST_SQLITE_FILE enables the SQLite live-DB test suite.
# Use ":memory:" for an in-memory database (no file created on disk).
GOBL_TEST_SQLITE_FILE=:memory:
