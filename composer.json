{
	"name": "silassare/gobl",
	"description": "Gobl allows you to use a Database Abstraction Layer (DBAL) and Object-Relational Mapping (ORM) to query your database with PHP.",
	"type": "library",
	"license": "MIT",
	"keywords": [
		"gobl",
		"ORM",
		"DBAL",
		"CRUD",
		"MySQL",
		"SQLite",
		"PostgreSQL",
		"PHP"
	],
	"require": {
		"php": ">=8.1",
		"ext-pdo": "*",
		"ext-json": "*",
		"ext-bcmath": "*",
		"silassare/php-utils": "^2.0.0",
		"oliup/code-generator": "^1.0.0",
		"silassare/blate": "^1.1.0"
	},
	"require-dev": {
		"oliup/oliup-cs-php": "dev-main",
		"roave/security-advisories": "dev-latest",
		"phpunit/phpunit": "^9.5.9",
		"vimeo/psalm": "^6.0"
	},
	"suggest": {
		"ext-pdo_mysql": "Required to use the MySQL driver.",
		"ext-sqlite3": "Required to use the SQLite driver.",
		"ext-pdo_pgsql": "Required to use the PostgreSQL driver."
	},
	"homepage": "https://github.com/silassare/gobl#readme",
	"archive": {
		"exclude": [
			"tests/",
			"docs/",
			".github/",
			".vscode/",
			"phpunit.xml.dist",
			"phpunit.xml",
			"psalm.xml"
		]
	},
	"autoload": {
		"psr-4": {
			"Gobl\\": "src/"
		},
		"files": [
			"src/bootstrap.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Gobl\\Tests\\": "tests/",
			"Gobl\\Tests\\Db\\": "tests/tmp/output/ORM_Db/"
		}
	},
	"authors": [
		{
			"name": "Emile Silas Sare",
			"homepage": "https://github.com/silassare"
		}
	],
	"prefer-stable": true,
	"minimum-stability": "dev",
	"extra": {
		"branch-alias": {
			"dev-main": "3.0.x-dev"
		}
	},
	"config": {
		"platform": {
			"php": "8.1.31"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
